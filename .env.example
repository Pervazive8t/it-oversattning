# Bas-URL till den svenska källsidan (utan avslutande slash)
SOURCE_URL=https://din-svenska-sida.se

# DeepL API-nyckel. Om du har en GRATIS DeepL-nyckel slutar den på ":fx"
# (då används automatiskt api-free.deepl.com). Pro-nycklar använder api.deepl.com.
DEEPL_API_KEY=din-deepl-nyckel-här

SOURCE_LANG=SV
TARGET_LANG=IT

PORT=3000
